PORT=3000
NODE_ENV=development

JWT_SECRET=replace_with_a_long_random_secret
SESSION_SECRET=replace_with_another_long_random_secret

# Local default:
# DATABASE_PATH=./database/ecowaste.db
#
# Render persistent disk example:
# DATABASE_PATH=/var/data/ecowaste.db
DATABASE_PATH=./database/ecowaste.db

# Comma-separated list for deployed frontend origins when calling the API directly.
# Example:
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Optional AI key
GEMINI_API_KEY=your_gemini_api_key
